{
  "id": "headroom",
  "uiHints": {
    "proxyUrl": {
      "label": "Proxy URL",
      "help": "Optional. URL of a Headroom proxy on localhost (example: http://127.0.0.1:8787). If omitted, plugin auto-detects defaults."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "proxyUrl": {
        "type": "string",
        "pattern": "^http:\\/\\/(localhost|127\\.0\\.0\\.1)(:\\d+)?$"
      },
      "autoStart": {
        "type": "boolean",
        "default": true
      },
      "startupTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 120000,
        "default": 20000
      }
    }
  },
  "capabilities": {
    "network": {
      "allow": [
        "http://localhost:*",
        "http://127.0.0.1:*"
      ]
    }
  }
}
